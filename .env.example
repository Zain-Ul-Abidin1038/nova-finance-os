# Finance OS Environment Variables Template
# Copy this file to .env and fill in your actual values

# AWS Credentials for Amazon Bedrock
# Get your credentials from: https://console.aws.amazon.com/iam/
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1

# Optional: AWS Session Token (if using temporary credentials)
# AWS_SESSION_TOKEN=your_session_token_here

# Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Create IAM user with Bedrock permissions in AWS Console
# 3. Enable Amazon Nova models in Bedrock console
# 4. Replace the placeholder values with your actual AWS credentials
# 5. Never commit .env to version control

# Required IAM Permissions:
# - bedrock:InvokeModel
# - bedrock:InvokeModelWithResponseStream
# 
# Models to enable in Bedrock:
# - amazon.nova-lite-v1:0 (reasoning)
# - amazon.titan-embed-text-v2:0 (embeddings)
# - amazon.nova-pro-v1:0 (multimodal vision)
